{
  "name": "channel-agent-runtime",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "simulate": "node src/cli.mjs simulate --config config/agents/missed-call-recovery.yaml",
    "simulate:salon": "node src/cli.mjs simulate --config config/agents/salon-telegram.yaml",
    "simulate:discord": "node src/cli.mjs simulate --config config/agents/discord-moderation.yaml",
    "simulate:slack": "node src/cli.mjs simulate --config config/agents/slack-workflow.yaml",
    "simulate:whatsapp": "node src/cli.mjs simulate --config config/agents/real-estate-whatsapp.yaml",
    "server": "node src/cli.mjs server --config config/agents/missed-call-recovery.yaml",
    "server:whatsapp": "node src/cli.mjs server --config config/agents/real-estate-whatsapp.yaml",
    "telegram": "node src/cli.mjs telegram --config config/agents/missed-call-recovery.yaml",
    "telegram:salon": "node src/cli.mjs telegram --config config/agents/salon-telegram.yaml",
    "discord": "node src/cli.mjs discord --config config/agents/missed-call-recovery.yaml",
    "discord:moderation": "node src/cli.mjs discord --config config/agents/discord-moderation.yaml",
    "slack": "node src/cli.mjs slack --config config/agents/missed-call-recovery.yaml",
    "slack:workflow": "node src/cli.mjs slack --config config/agents/slack-workflow.yaml",
    "test": "node scripts/smoke.mjs && node scripts/demo-smoke.mjs && node scripts/command-smoke.mjs && node scripts/http-smoke.mjs && node scripts/provider-check.mjs",
    "test:smoke": "node scripts/smoke.mjs",
    "test:demos": "node scripts/demo-smoke.mjs",
    "test:commands": "node scripts/command-smoke.mjs",
    "test:http": "node scripts/http-smoke.mjs",
    "test:providers": "node scripts/provider-check.mjs",
    "test:llm": "node scripts/llm-smoke.mjs",
    "check:whatsapp": "node scripts/whatsapp-check.mjs",
    "check:whatsapp-cloud": "node scripts/whatsapp-cloud-check.mjs",
    "check:discord": "node scripts/discord-check.mjs",
    "check:slack": "node scripts/slack-check.mjs",
    "send-test:discord": "node scripts/discord-send-test.mjs",
    "send-test:slack": "node scripts/slack-send-test.mjs",
    "send-test:telegram": "node scripts/telegram-send-test.mjs"
  },
  "dependencies": {
    "@langchain/langgraph": "^1.4.8",
    "@slack/bolt": "^5.0.0",
    "discord.js": "^14.22.1",
    "dotenv": "^17.2.3",
    "grammy": "^1.38.4",
    "yaml": "^2.8.2"
  }
}
